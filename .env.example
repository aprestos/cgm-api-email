# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Default sender. Must use a domain verified in Resend.
# Format: "Display Name <address@your-domain.com>"
RESEND_FROM=Congrem <noreply@your-domain.com>

# Optional shared secret. If set, requests must send
# Authorization: Bearer <EMAIL_API_KEY>. Leave unset to disable auth (dev only).
EMAIL_API_KEY=

# Port the email API listens on (default 3001).
PORT=3001
